# Production environment for voxpo.me
# Copy to .env and fill in all CHANGE_ME values before running: make main

# Database
POSTGRES_DB=voxpopuli
POSTGRES_USER=vox
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_URL=redis://redis:6379/0

# Backend
SECRET_KEY=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING
JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem

# Email (password reset) — set to your SMTP provider
SMTP_HOST=CHANGE_ME
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=noreply@voxpo.me

# LLM via OpenRouter
OPENROUTER_API_KEY=CHANGE_ME_sk-or-...
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
LLM_MONTHLY_BUDGET_USD=20

# Frontend public URLs — production
NEXT_PUBLIC_API_URL=https://voxpo.me
NEXT_PUBLIC_SOCKET_URL=https://voxpo.me

# OAuth 2.0 — register callbacks at https://voxpo.me/api/auth/callback/<provider>
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME
FT_CLIENT_ID=CHANGE_ME
FT_CLIENT_SECRET=CHANGE_ME
OAUTH_REDIRECT_BASE=https://voxpo.me

# Security
ALLOWED_HOSTS=voxpo.me,localhost

# Production flags
ENABLE_E2E_TEST_SUPPORT=false
